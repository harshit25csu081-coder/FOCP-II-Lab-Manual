#include<iostream>
#include<string>
using namespace std;
class Account{
    
    protected:
    string acc_no;
    float balance;
public:
Account(){ // base class
    cout<<"\n default account";
    acc_no="NA";balance=0;
}
Account(string a,float b){
   cout<<"\n prameter account";
 acc_no=a;
 balance=b;
}

void displayAccount(){
cout<<"\naccount number:"<<acc_no<<"\nbalance:"<<balance;
}

};
class SavingAccount:public Account{//derived class
private:
float interestrate;
public:
SavingAccount(){
    interestrate=0;
}
SavingAccount(string acc_no,int balance,float interestrate) :Account(acc_no,balance){
this-> interestrate=interestrate;
}
 void calculateinterest(){
        float interest=(balance*interestrate)/100;
        cout<<"Interest rate: "<<interestrate<<endl;
        cout<<"Total balance: "<<balance+interest<<endl;
    }
};

int main(){
    SavingAccount s1;
    SavingAccount s2("A101",45000,5);

    cout<<"\nUsing parameterized constructor"<<endl;
    s2.displayAccount();
    s2.calculateinterest();

    return 0;
}
