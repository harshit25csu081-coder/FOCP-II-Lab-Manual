#include <iostream>
using namespace std;

int main()
{
    for(int i = 5; i >= 1; i--)   // rows
    {
        for(int j = 5; j >= 6 - i; j--)
        {
            cout << j << " ";
        }
        cout << endl;
    }

    return 0;
}

question 23
#include <iostream>
using namespace std;

int main()
{
    int rows = 8, cols = 8;

    for(int i = 1; i <= rows; i++)
    {
        for(int j = 1; j <= cols; j++)
        {
            if(i == 1 || i == rows || j == 1 || j == cols)
                cout << "*";
            else
                cout << " ";
        }
        cout << endl;
    }

    return 0;
}
