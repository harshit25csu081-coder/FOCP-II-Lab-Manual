//multiplication of two matrix


#include <iostream>
using namespace std;

int main()
{
    int a[10][10], b[10][10], mul[10][10];
    int m,n,p,q;

    cout<<"Enter rows and columns of first matrix: ";
    cin>>m>>n;

    cout<<"Enter rows and columns of second matrix: ";
    cin>>p>>q;

    if(n!=p)
    {
        cout<<"Matrix multiplication not possible";
        return 0;
    }

    cout<<"Enter elements of first matrix:\n";
    for(int i=0;i<m;i++)
    {
        for(int j=0;j<n;j++)
        cin>>a[i][j];
    }

    cout<<"Enter elements of second matrix:\n";
    for(int i=0;i<p;i++)
    {
        for(int j=0;j<q;j++)
        cin>>b[i][j];
    }

    for(int i=0;i<m;i++)
    {
        for(int j=0;j<q;j++)
        {
            mul[i][j]=0;
            for(int k=0;k<n;k++)
            mul[i][j]+=a[i][k]*b[k][j];
        }
    }

    cout<<"\nMultiplication of matrices:\n";
    for(int i=0;i<m;i++)
    {
        for(int j=0;j<q;j++)
        cout<<mul[i][j]<<" ";
        cout<<endl;
    }

    return 0;
}
