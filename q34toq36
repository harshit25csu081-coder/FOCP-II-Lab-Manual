//transpose of matrix 
#include <iostream>
using namespace std;

int main()
{
    int a[3][3], t[3][3];

    cout<<"Enter elements of matrix:\n";
    for(int i=0;i<3;i++)
    {
        for(int j=0;j<3;j++)
        cin>>a[i][j];
    }

    for(int i=0;i<3;i++)
    {
        for(int j=0;j<3;j++)
        t[j][i]=a[i][j];
    }

    cout<<"\nTranspose matrix:\n";
    for(int i=0;i<3;i++)
    {
        for(int j=0;j<3;j++)
        cout<<t[i][j]<<" ";
        cout<<endl;
    }

    return 0;
}


